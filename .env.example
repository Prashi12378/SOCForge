# SOCForge Environment Variables Template

# --- Frontend (Netlify / Vercel Settings) ---
# The base URL of your deployed backend API (e.g., https://api.socforge.com)
# Leave empty during local development if using the Vite proxy.
VITE_API_URL=

# --- Backend (Server Settings) ---
PROJECT_NAME=SOCForge
DATABASE_URL=postgresql://socforge:socforge_password@localhost:5432/socforge_db
SECRET_KEY=generate-a-secure-random-key-here
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
